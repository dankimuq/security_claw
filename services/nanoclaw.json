{
  "service_name": "nanoclaw",
  "repo_path": ".",
  "dependency_scan": {
    "command": "npm",
    "args": ["audit", "--omit=dev", "--audit-level=high", "--json"]
  },
  "sast_scan": {
    "command": "semgrep",
    "args": ["scan", "--config", "p/default", "--json"]
  },
  "container_scan": {
    "command": "trivy",
    "args": ["fs", "--scanners", "vuln,misconfig", "--severity", "HIGH,CRITICAL", "--format", "json", "--no-progress", "."]
  },
  "time_budget_sec": 1200
}
